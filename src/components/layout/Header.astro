---
/**
 * @file src/components/layout/Header.astro
 * @summary UI-Komponente: layout/Header — wiederverwendbarer Markup-Block.
 */
import { navClusters, professionalItHref, resolveActiveClusterId } from '../../config/navigation';
import { isProfessionalShell } from '../../config/site-variant';
import {
  professionalNavItemsDe,
  professionalNavItemsEn,
  professionalItDeHref,
  professionalItEnHref,
  resolveProfessionalNavHref,
  navLinkClass,
  navLinkMobileClass,
  langLinkClass,
} from '../../config/professional-navigation';

interface Props {
  variant?: 'default' | 'launch';
  locale?: 'de' | 'en';
}

const { variant = 'default', locale = 'de' } = Astro.props;
const isProfessional = isProfessionalShell(variant);

const clusters = navClusters;
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const activeClusterId = resolveActiveClusterId(Astro.url.pathname);
const homeHref = isProfessional
  ? locale === 'en'
    ? professionalItEnHref
    : professionalItDeHref
  : '/';
const homeLabel = isProfessional
  ? locale === 'en'
    ? 'Back to Professional IT page'
    : 'Zur Professional-IT-Seite'
  : 'Zur Startseite von Aydin Mokhtary';

const professionalNavItems = locale === 'en' ? professionalNavItemsEn : professionalNavItemsDe;
const professionalBaseHref = locale === 'en' ? professionalItEnHref : professionalItDeHref;
const langToggleHref = locale === 'en' ? professionalItDeHref : professionalItEnHref;
const langToggleLabel = locale === 'en' ? 'DE' : 'EN';
const langToggleAria =
  locale === 'en' ? 'Zur deutschen Version wechseln' : 'Switch to English version';
const mobilePanelLabel = isProfessional
  ? locale === 'en'
    ? 'Page navigation'
    : 'Seitennavigation'
  : 'Hauptnavigation';
const mobileNavAria = isProfessional
  ? locale === 'en'
    ? 'Page navigation mobile'
    : 'Seitennavigation mobil'
  : 'Hauptnavigation mobil';
---

<header
  data-site-header
  class="sticky top-0 z-50 border-b border-[var(--color-border-soft)] bg-white/80 backdrop-blur-xl"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <a
      href={homeHref}
      aria-label={homeLabel}
      class="group inline-flex items-center gap-3"
    >
      <span
        aria-hidden="true"
        class="flex h-10 w-10 items-center justify-center rounded-2xl border border-[var(--color-border-soft)] bg-[linear-gradient(180deg,#F8FCFB_0%,#EEF7F5_100%)] shadow-[0_8px_24px_rgba(44,51,51,0.06)] transition-transform duration-200 motion-safe:group-hover:-translate-y-0.5"
      >
        <span class="h-4 w-4 rotate-45 rounded-[4px] border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10"></span>
      </span>

      <span class="flex flex-col">
        <span class="text-sm leading-none text-[var(--color-text-secondary)]">Aydin Mokhtary</span>
        <span class="mt-1 text-base font-semibold leading-none tracking-tight text-[var(--color-base-dark)]">
          {isProfessional ? 'Professional IT' : 'mokhtary.de'}
        </span>
      </span>
    </a>

    {
      isProfessional ? (
        <nav aria-label={mobilePanelLabel} class="hidden lg:block">
          <ul class="flex items-center gap-1" role="list">
            {professionalNavItems.map((item) => (
              <li>
                <a
                  href={resolveProfessionalNavHref(item.hash, current, professionalBaseHref)}
                  class={navLinkClass}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li>
              <a href={langToggleHref} class={langLinkClass} aria-label={langToggleAria}>
                {langToggleLabel}
              </a>
            </li>
          </ul>
        </nav>
      ) : (
        <nav aria-label="Hauptnavigation" class="hidden lg:block">
          <ul class="flex items-center gap-1" role="list">
            {
              clusters.map((cluster) => {
            const isActive = activeClusterId === cluster.id;
            const panelId = `nav-panel-${cluster.id}`;
            const toggleId = `nav-toggle-${cluster.id}`;
            return (
              <li class="nav-cluster" data-nav-cluster data-active={isActive ? 'true' : undefined}>
                <span class="nav-cluster__shell inline-flex items-center rounded-full">
                  <a
                    href={cluster.hub}
                    aria-current={cluster.hub === current ? 'page' : undefined}
                    class={`nav-cluster__link inline-flex items-center gap-1.5 rounded-l-full pl-4 pr-2 py-2 text-sm font-medium text-[var(--color-text-secondary)] transition-colors duration-200 hover:bg-[var(--color-surface-light)] hover:text-[var(--color-base-dark)]`}
                  >
                    <span
                      aria-hidden="true"
                      class={`nav-cluster__dot h-1.5 w-1.5 rounded-full ${cluster.tone === 'growth' ? 'bg-[var(--growth-violet)]' : 'bg-[var(--systems-steel)]'}`}
                    />
                    {cluster.label}
                  </a>
                  <button
                    type="button"
                    id={toggleId}
                    data-nav-cluster-toggle
                    aria-expanded="false"
                    aria-controls={panelId}
                    aria-label={`${cluster.label} Untermenü öffnen`}
                    class="nav-cluster__btn inline-flex items-center justify-center rounded-r-full pr-3 pl-1.5 py-2 text-[var(--color-text-secondary)] transition-colors duration-200 hover:bg-[var(--color-surface-light)] hover:text-[var(--color-base-dark)]"
                  >
                    <svg
                      class="nav-cluster__chev"
                      aria-hidden="true"
                      width="10"
                      height="10"
                      viewBox="0 0 10 10"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M2.5 4 5 6.5 7.5 4" />
                    </svg>
                  </button>
                </span>

                <div
                  id={panelId}
                  data-nav-cluster-panel
                  class="nav-cluster__panel absolute left-0 top-full z-10 mt-2 w-72 rounded-2xl border border-[var(--color-border-soft)] bg-white/95 p-2 shadow-[0_20px_50px_rgba(44,51,51,0.12)] backdrop-blur-xl"
                  hidden
                >
                  <ul role="list">
                    <li>
                      <a
                        href={cluster.hub}
                        aria-current={cluster.hub === current ? 'page' : undefined}
                        class="group flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-semibold text-[var(--color-base-dark)] transition-colors hover:bg-[var(--color-surface-light)] aria-[current=page]:bg-[var(--color-surface-light)] aria-[current=page]:text-[var(--color-primary)]"
                      >
                        <span class="inline-flex items-center gap-2">
                          <span
                            aria-hidden="true"
                            class={`h-1.5 w-1.5 rounded-full ${cluster.tone === 'growth' ? 'bg-[var(--growth-violet)]' : 'bg-[var(--systems-steel)]'}`}
                          />
                          {cluster.hubLabel}
                        </span>
                        <svg
                          aria-hidden="true"
                          class="chevron-nudge text-[var(--color-text-secondary)] group-hover:text-[var(--color-primary)]"
                          width="12"
                          height="12"
                          viewBox="0 0 14 14"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M3 7h8" />
                          <path d="M7.5 3.5 11 7l-3.5 3.5" />
                        </svg>
                      </a>
                    </li>
                    <li role="separator" aria-hidden="true">
                      <span class="my-1 mx-2 block border-t border-[var(--color-border-soft)]"></span>
                    </li>
                    {cluster.links.map((l) => (
                      <li>
                        <a
                          href={l.href}
                          aria-current={l.href === current ? 'page' : undefined}
                          class="flex items-center rounded-xl px-3 py-2.5 text-sm font-medium text-[var(--color-base-dark)] transition-colors hover:bg-[var(--color-surface-light)] aria-[current=page]:bg-[var(--color-surface-light)] aria-[current=page]:text-[var(--color-primary)]"
                        >
                          {l.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            );
          })
        }
        <li>
          <a
            href={professionalItHref}
            aria-current={current === professionalItHref ? 'page' : undefined}
            class="inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium text-[var(--color-text-secondary)] transition-colors duration-200 hover:bg-[var(--color-surface-light)] hover:text-[var(--color-base-dark)] aria-[current=page]:text-[var(--color-primary)]"
          >
            <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-[var(--systems-steel)]" />
            Professional IT
          </a>
        </li>
      </ul>
    </nav>
      )
    }

    <div class="flex items-center gap-3">
      <button
        type="button"
        data-nav-toggle
        class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--color-border-soft)] bg-white text-[var(--color-base-dark)] transition-colors duration-200 hover:bg-[var(--color-surface-light)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary)] lg:hidden"
        aria-expanded="false"
        aria-controls="site-mobile-panel"
        aria-label={locale === 'en' ? 'Open navigation' : 'Navigation öffnen'}
      >
        <span class="flex flex-col gap-1.5" aria-hidden="true">
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
        </span>
      </button>
    </div>
  </div>

  <div
    data-nav-backdrop
    class="fixed inset-0 z-40 bg-[var(--color-base-dark)]/25 backdrop-blur-[2px] motion-safe:transition-opacity motion-safe:duration-200 lg:hidden"
    hidden
    aria-hidden="true"
  >
  </div>

  <div
    id="site-mobile-panel"
    data-nav-panel
    role="dialog"
    aria-modal="true"
    aria-label={mobilePanelLabel}
    class="fixed inset-x-3 top-[4.75rem] z-50 max-h-[min(78vh,calc(100dvh-5.5rem))] overflow-y-auto rounded-2xl border border-[var(--color-border-soft)] bg-white/95 p-5 shadow-[0_24px_60px_rgba(44,51,51,0.12)] backdrop-blur-xl motion-safe:transition motion-safe:duration-200 motion-safe:ease-out lg:hidden"
    hidden
  >
    {
      isProfessional ? (
        <nav aria-label={mobileNavAria} class="grid gap-1">
          {professionalNavItems.map((item) => (
            <a
              href={resolveProfessionalNavHref(item.hash, current, professionalBaseHref)}
              class={navLinkMobileClass}
            >
              {item.label}
            </a>
          ))}
          <div class="mt-4 border-t border-[var(--color-border-soft)] pt-4">
            <a href={langToggleHref} class={navLinkMobileClass} aria-label={langToggleAria}>
              {langToggleLabel}
            </a>
          </div>
        </nav>
      ) : (
        <nav aria-label={mobileNavAria} class="grid gap-6">
          {
            clusters.map((cluster) => (
              <div>
                <a
                  href={cluster.hub}
                  aria-current={cluster.hub === current ? 'page' : undefined}
                  class="group mb-3 flex items-center justify-between rounded-xl px-2 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-base-dark)] aria-[current=page]:text-[var(--color-primary)]"
                >
                  <span class="inline-flex items-center gap-2">
                    <span
                      aria-hidden="true"
                      class={`h-1.5 w-1.5 rounded-full ${cluster.tone === 'growth' ? 'bg-[var(--growth-violet)]' : 'bg-[var(--systems-steel)]'}`}
                    />
                    {cluster.label}
                  </span>
                  <span aria-hidden="true" class="text-[0.65rem] font-medium tracking-normal normal-case text-[var(--color-text-secondary)] group-hover:text-[var(--color-primary)]">
                    →
                  </span>
                </a>
                <ul class="grid gap-1" role="list">
                  {cluster.links.map((l) => (
                    <li>
                      <a
                        href={l.href}
                        aria-current={l.href === current ? 'page' : undefined}
                        class="block rounded-xl px-4 py-3 text-base font-medium text-[var(--color-base-dark)] transition-colors hover:bg-[var(--color-surface-light)] aria-[current=page]:bg-[var(--color-surface-light)] aria-[current=page]:text-[var(--color-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary)]"
                      >
                        {l.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
          <div class="border-t border-[var(--color-border-soft)] pt-4">
            <a
              href={professionalItHref}
              aria-current={current === professionalItHref ? 'page' : undefined}
              class="block rounded-xl px-4 py-3 text-base font-medium text-[var(--color-base-dark)] transition-colors hover:bg-[var(--color-surface-light)] aria-[current=page]:bg-[var(--color-surface-light)] aria-[current=page]:text-[var(--color-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary)]"
            >
              Professional IT
            </a>
          </div>
        </nav>
      )
    }
  </div>
</header>
