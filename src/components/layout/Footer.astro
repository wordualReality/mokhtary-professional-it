---
/**
 * @file src/components/layout/Footer.astro
 * @summary Professional IT site footer: role claim and legal links only.
 */
import {
  professionalLegalPaths,
  professionalLegalPathsEn,
} from '../../config/professional-navigation';
import { professionalFooterCopyDe, professionalFooterCopyEn } from '../../data/professional-footer';

interface Props {
  locale?: 'de' | 'en';
}

const { locale = 'de' } = Astro.props;

const impressumHref =
  locale === 'en' ? professionalLegalPathsEn.imprint : professionalLegalPaths.impressum;
const datenschutzHref =
  locale === 'en' ? professionalLegalPathsEn.privacy : professionalLegalPaths.datenschutz;
const impressumLabel = locale === 'en' ? 'Imprint' : 'Impressum';
const datenschutzLabel = locale === 'en' ? 'Privacy' : 'Datenschutz';
const footerCopy = locale === 'en' ? professionalFooterCopyEn : professionalFooterCopyDe;
---

<footer class="border-t border-[var(--color-border-soft)] bg-white">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-8">
    <div class="max-w-md">
      <p class="inline-flex items-center gap-2 text-base font-semibold tracking-tight text-[var(--color-base-dark)]">
        <span aria-hidden="true" class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-[var(--color-primary)] text-xs font-semibold text-white">AM</span>
        Aydin Mokhtary
      </p>
      <p class="mt-2 text-sm leading-6 text-[var(--color-text-secondary)]">
        {footerCopy.role}
      </p>
      <div class="mt-4 flex flex-col gap-1 text-xs uppercase tracking-[0.2em] text-[var(--color-primary)]">
        {footerCopy.claimLines.map((line) => (
          <span>{line}</span>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-[var(--color-border-soft)] pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-[var(--color-text-secondary)]">
        © 2026 Aydin Mokhtary.
        <a href="mailto:kontakt@mokhtary.de" class="ml-2 hover:text-[var(--color-base-dark)]">kontakt@mokhtary.de</a>
      </p>
      <nav aria-label={locale === 'en' ? 'Legal' : 'Rechtliches'} class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[var(--color-text-secondary)]">
        <a href={impressumHref} class="transition-colors hover:text-[var(--color-base-dark)]">{impressumLabel}</a>
        <a href={datenschutzHref} class="transition-colors hover:text-[var(--color-base-dark)]">{datenschutzLabel}</a>
        <span class="text-xs text-[var(--color-text-secondary)]">Handgebaut in Astro · ohne Tracker.</span>
      </nav>
    </div>
  </div>
</footer>
