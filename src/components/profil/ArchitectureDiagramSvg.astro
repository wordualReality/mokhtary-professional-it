---
/**
 * @file src/components/profil/ArchitectureDiagramSvg.astro
 * @summary Natives SVG-Architekturdiagramm mit gestaffelter Hero-Animation.
 */
const ALT =
  'Isometrisches Diagramm: Scope und Delivery, Risiko, Fluss Fach, Anforderung, Bau, Cloud und Server';
---

<div class="arch-diagram arch-diagram--svg" data-arch-diagram>
  <div class="arch-diagram__stage">
    <svg
      class="arch-diagram__svg"
      viewBox="0 0 1024 571"
      width="1024"
      height="571"
      role="img"
      aria-label={ALT}
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <pattern id="arch-grid" width="28" height="28" patternUnits="userSpaceOnUse">
          <path
            d="M 28 0 L 0 0 0 28"
            fill="none"
            stroke="#d8ddd8"
            stroke-width="1"></path>
        </pattern>
        <filter id="arch-soft-shadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="8" dy="14" stdDeviation="10" flood-color="#2c3333" flood-opacity="0.14"></feDropShadow>
        </filter>
        <linearGradient id="arch-block-fach-side" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3a4244"></stop>
          <stop offset="100%" stop-color="#252b2c"></stop>
        </linearGradient>
        <linearGradient id="arch-block-anf-side" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#6f939b"></stop>
          <stop offset="100%" stop-color="#4f7279"></stop>
        </linearGradient>
        <linearGradient id="arch-block-bau-side" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#9ab08a"></stop>
          <stop offset="100%" stop-color="#6f8660"></stop>
        </linearGradient>
      </defs>

      <rect width="1024" height="571" fill="#f8f6ef"></rect>

      <g class="arch-diagram__svg-layer" data-arch-layer="grid">
        <g filter="url(#arch-soft-shadow)" transform="translate(248 108)">
          <path d="M 0 52 L 420 0 L 420 248 L 0 300 Z" fill="#ffffff" stroke="#d0d6d0" stroke-width="1.5"></path>
          <path d="M 0 52 L 420 0 L 420 248 L 0 300 Z" fill="url(#arch-grid)" opacity="0.85"></path>
          <rect x="318" y="228" width="88" height="52" fill="#f4f6f2" stroke="#d8ddd8" stroke-width="1"></rect>
          <line x1="326" y1="244" x2="398" y2="244" stroke="#e2e6e0" stroke-width="2"></line>
          <line x1="326" y1="256" x2="378" y2="256" stroke="#e2e6e0" stroke-width="2"></line>
          <line x1="326" y1="268" x2="388" y2="268" stroke="#e2e6e0" stroke-width="2"></line>
        </g>
      </g>

      <g class="arch-diagram__svg-layer arch-diagram__connectors" data-arch-layer="connectors">
        <circle cx="118" cy="118" r="5" fill="#b8c0bc"></circle>
        <circle cx="138" cy="468" r="5" fill="#b8c0bc"></circle>
        <circle cx="318" cy="318" r="5" fill="#b8c0bc"></circle>
        <circle cx="868" cy="108" r="5" fill="#b8c0bc"></circle>
        <circle cx="848" cy="448" r="5" fill="#b8c0bc"></circle>
        <path
          class="arch-diagram__connector-line"
          d="M 148 128 C 200 140, 220 200, 280 250"
          fill="none"
          stroke="#a8b0ac"
          stroke-width="2"
          stroke-linecap="round"></path>
        <path
          class="arch-diagram__connector-line"
          d="M 158 448 C 210 400, 250 360, 300 330"
          fill="none"
          stroke="#a8b0ac"
          stroke-width="2"
          stroke-linecap="round"></path>
        <path
          class="arch-diagram__connector-line"
          d="M 668 148 C 720 130, 780 118, 830 108"
          fill="none"
          stroke="#a8b0ac"
          stroke-width="2"
          stroke-linecap="round"></path>
        <path
          class="arch-diagram__connector-line"
          d="M 688 318 C 740 360, 790 400, 828 438"
          fill="none"
          stroke="#a8b0ac"
          stroke-width="2"
          stroke-linecap="round"></path>
        <path
          class="arch-diagram__connector-line arch-diagram__connector-line--loop"
          d="M 398 318 L 468 278 L 538 238 L 598 268 L 528 308 L 458 338 Z"
          fill="none"
          stroke="#9aa3a8"
          stroke-width="1.75"
          stroke-linejoin="round"></path>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="clipboard" filter="url(#arch-soft-shadow)">
        <g transform="translate(52 42)">
          <rect x="8" y="28" width="118" height="148" rx="6" fill="#e8ebe6" stroke="#c8cec8" stroke-width="1.5"></rect>
          <path d="M 36 28 L 36 14 Q 36 4 52 4 L 88 4 Q 104 4 104 14 L 104 28" fill="#d4d9d4" stroke="#c8cec8" stroke-width="1.5"></path>
          <rect x="22" y="48" width="90" height="118" rx="4" fill="#ffffff"></rect>
          <text x="32" y="68" fill="#6b7570" font-size="9" font-weight="600" font-family="system-ui,sans-serif">Scope</text>
          <text x="78" y="68" fill="#6b7570" font-size="9" font-weight="600" font-family="system-ui,sans-serif">Delivery</text>
          <line x1="28" y1="76" x2="106" y2="76" stroke="#e8ece8" stroke-width="1"></line>
          <rect x="30" y="86" width="10" height="10" rx="2" fill="#5e848c"></rect>
          <line x1="46" y1="92" x2="100" y2="92" stroke="#d0d6d0" stroke-width="3" stroke-linecap="round"></line>
          <rect x="30" y="104" width="10" height="10" rx="2" fill="#5e848c"></rect>
          <line x1="46" y1="110" x2="92" y2="110" stroke="#d0d6d0" stroke-width="3" stroke-linecap="round"></line>
          <rect x="30" y="122" width="10" height="10" rx="2" fill="#5e848c"></rect>
          <line x1="46" y1="128" x2="98" y2="128" stroke="#d0d6d0" stroke-width="3" stroke-linecap="round"></line>
          <rect x="30" y="140" width="10" height="10" rx="2" fill="#8a7a9e"></rect>
          <line x1="46" y1="146" x2="88" y2="146" stroke="#d0d6d0" stroke-width="3" stroke-linecap="round"></line>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="risiko" filter="url(#arch-soft-shadow)">
        <g transform="translate(78 398)">
          <rect x="0" y="16" width="88" height="52" rx="6" fill="#e0dce8" transform="rotate(-4 44 44)"></rect>
          <rect x="6" y="8" width="88" height="52" rx="6" fill="#ebe8f2" transform="rotate(2 50 34)"></rect>
          <rect x="12" y="0" width="92" height="56" rx="6" fill="#d8d0e8" stroke="#b8aec8" stroke-width="1"></rect>
          <circle cx="36" cy="28" r="10" fill="#8a7a9e"></circle>
          <path d="M 32 36 Q 36 32 40 36" fill="none" stroke="#6a5a7e" stroke-width="1.5"></path>
          <text x="52" y="32" fill="#4a4458" font-size="11" font-weight="600" font-family="system-ui,sans-serif">Risiko</text>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="fach" filter="url(#arch-soft-shadow)">
        <g transform="translate(318 318)">
          <path d="M 0 36 L 52 8 L 104 36 L 52 64 Z" fill="#2c3333"></path>
          <path d="M 0 36 L 0 72 L 52 100 L 52 64 Z" fill="url(#arch-block-fach-side)"></path>
          <path d="M 52 64 L 52 100 L 104 72 L 104 36 Z" fill="#1e2425"></path>
          <text x="52" y="48" text-anchor="middle" fill="#ffffff" font-size="12" font-weight="600" font-family="system-ui,sans-serif">Fach</text>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="anforderung" filter="url(#arch-soft-shadow)">
        <g transform="translate(448 258)">
          <path d="M 0 36 L 52 8 L 104 36 L 52 64 Z" fill="#5e848c"></path>
          <path d="M 0 36 L 0 72 L 52 100 L 52 64 Z" fill="url(#arch-block-anf-side)"></path>
          <path d="M 52 64 L 52 100 L 104 72 L 104 36 Z" fill="#4a6d74"></path>
          <text x="52" y="46" text-anchor="middle" fill="#ffffff" font-size="10" font-weight="600" font-family="system-ui,sans-serif">Anforderung</text>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="bau" filter="url(#arch-soft-shadow)">
        <g transform="translate(578 198)">
          <path d="M 0 36 L 52 8 L 104 36 L 52 64 Z" fill="#8faa7c"></path>
          <path d="M 0 36 L 0 72 L 52 100 L 52 64 Z" fill="url(#arch-block-bau-side)"></path>
          <path d="M 52 64 L 52 100 L 104 72 L 104 36 Z" fill="#6f8660"></path>
          <text x="52" y="48" text-anchor="middle" fill="#2c3333" font-size="12" font-weight="600" font-family="system-ui,sans-serif">Bau</text>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="cloud" filter="url(#arch-soft-shadow)">
        <g transform="translate(828 58)">
          <path
            d="M 24 48 C 8 48 0 38 0 28 C 0 16 10 8 22 8 C 24 2 32 0 42 0 C 58 0 68 12 68 26 C 80 26 88 34 88 44 C 88 54 78 58 68 58 Z"
            fill="#ffffff"
            stroke="#c8cec8"
            stroke-width="2"></path>
        </g>
      </g>

      <g class="arch-diagram__svg-layer" data-arch-layer="server" filter="url(#arch-soft-shadow)">
        <g transform="translate(858 398)">
          <path d="M 0 12 L 48 0 L 48 88 L 0 100 Z" fill="#3a4244"></path>
          <path d="M 0 12 L 0 100 L 48 88 L 48 0 Z" fill="#2c3333"></path>
          <rect x="10" y="28" width="28" height="6" rx="2" fill="#9ab0a8"></rect>
          <rect x="10" y="42" width="28" height="6" rx="2" fill="#c5d8d0"></rect>
          <rect x="10" y="56" width="28" height="6" rx="2" fill="#9ab0a8"></rect>
        </g>
      </g>
    </svg>
  </div>
</div>
