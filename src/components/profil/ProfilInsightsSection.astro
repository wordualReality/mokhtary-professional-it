---
/**
 * @file src/components/profil/ProfilInsightsSection.astro
 * @summary UI-Komponente: profil/ProfilInsightsSection — wiederverwendbarer Markup-Block.
 */
import { getProfilContent, type ProfilLocale } from '../../data/profil-content.locale';

interface Props {
  locale?: ProfilLocale;
}

const { locale = 'de' } = Astro.props;
const { insights, insightsSection } = getProfilContent(locale);
---
    <section
      id="praxis"
      aria-labelledby="profil-insights-heading"
      class="profil-band profil-band--insights scroll-mt-24 border-b border-[var(--color-border-soft)]"
    >
      <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-24">
        <header class="mb-10 max-w-2xl" data-reveal>
          <div class="profil-section-accent" aria-hidden="true"></div>
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-primary)]">
            {insightsSection.kicker}
          </p>
          <h2
            id="profil-insights-heading"
            class="mt-3 text-3xl font-semibold tracking-tight text-[var(--color-base-dark)] md:text-4xl"
          >
            {insightsSection.headline}
          </h2>
        </header>

        <ul
          class="insights-grid"
          role="list"
          data-reveal
          data-prof-insights-grid
          data-reveal-delay="120"
        >
          {insights.map((p, i) => (
            <li class="insights-grid__item" style={`--i:${i}`}>
              <details
                id={`profil-insight-${i}`}
                class={`insight-card insight-card--expandable insight-card--${p.visual}`}
                data-insight-card
                data-insight-type={p.visual}
              >
                <summary class="insight-card__summary">
                  <div class="insight-card__summary-inner">
                    <div class="insight-card__viz" data-insight-viz aria-hidden="true">
                      {p.visual === 'requirements' && (
                        <div class="insight-viz insight-viz--req">
                          <div class="insight-viz-req__spec">
                            <div class="insight-viz-req__chrome">
                              <span></span><span></span><span></span>
                            </div>
                            <div class="insight-viz-req__row">
                              <button
                                type="button"
                                class="insight-viz-req__pill insight-viz-req__pill--a"
                                data-req-pill="a"
                                aria-pressed="false"
                              >
                                A
                              </button>
                              <span class="insight-viz-req__vs">oder</span>
                              <button
                                type="button"
                                class="insight-viz-req__pill insight-viz-req__pill--b"
                                data-req-pill="b"
                                aria-pressed="false"
                              >
                                B
                              </button>
                            </div>
                            <div class="insight-viz-req__ruler" aria-hidden="true"></div>
                            <span class="insight-viz-req__status" data-req-status>Freigabe offen</span>
                          </div>
                        </div>
                      )}
                      {p.visual === 'bridge' && (
                        <div class="insight-viz insight-viz--bridge">
                          <span class="insight-viz-br__pill insight-viz-br__pill--l">FB</span>
                          <span class="insight-viz-br__track">
                            <span class="insight-viz-br__arc"></span>
                            <span class="insight-viz-br__pulse" data-bridge-pulse></span>
                          </span>
                          <span class="insight-viz-br__pill insight-viz-br__pill--r">IT</span>
                        </div>
                      )}
                      {p.visual === 'provider' && (
                        <div class="insight-viz insight-viz--prov">
                          <div class="insight-viz-prov__track">
                            <span class="insight-viz-prov__k">Soll</span>
                            <div class="insight-viz-prov__meter">
                              <i class="insight-viz-prov__fill insight-viz-prov__fill--soll"></i>
                            </div>
                          </div>
                          <div class="insight-viz-prov__track">
                            <span class="insight-viz-prov__k">Ist</span>
                            <div class="insight-viz-prov__meter">
                              <i class="insight-viz-prov__fill insight-viz-prov__fill--ist"></i>
                            </div>
                          </div>
                          <div class="insight-viz-prov__alerts" aria-hidden="true">
                            <span class="insight-viz-prov__bang">!</span>
                            <span class="insight-viz-prov__bang">!</span>
                            <span class="insight-viz-prov__bang">!</span>
                          </div>
                        </div>
                      )}
                      {p.visual === 'ai' && (
                        <div class="insight-viz insight-viz--ai">
                          <div class="insight-viz-ai__stack" aria-hidden="true">
                            <div class="insight-viz-ai__brand">
                              <svg
                                class="insight-viz-ai__svg"
                                viewBox="0 0 48 48"
                                width="42"
                                height="42"
                                role="presentation"
                                focusable="false"
                              >
                                <defs>
                                  <linearGradient id="insight-ai-flower" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#314e56"></stop>
                                    <stop offset="45%" stop-color="#395b64"></stop>
                                    <stop offset="100%" stop-color="#7eb4c0"></stop>
                                  </linearGradient>
                                </defs>
                                <g class="insight-viz-ai__flower" transform="translate(24 24)">
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(0)"></ellipse>
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(60)"></ellipse>
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(120)"></ellipse>
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(180)"></ellipse>
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(240)"></ellipse>
                                  <ellipse
                                    class="insight-viz-ai__petal"
                                    rx="12"
                                    ry="5.5"
                                    fill="url(#insight-ai-flower)"
                                    transform="rotate(300)"></ellipse>
                                  <circle
                                    r="5.25"
                                    fill="#f8fbf6"
                                    stroke="#395b64"
                                    stroke-width="0.85"
                                    opacity="0.98"></circle>
                                </g>
                              </svg>
                            </div>
                            <div class="insight-viz-ai__sigils">
                              <span class="insight-viz-ai__sig">
                                <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                                  <ellipse cx="12" cy="5" rx="7" ry="2.5" stroke="currentColor" stroke-width="1.75"
                                  ></ellipse>
                                  <path
                                    d="M5 5v3.2c0 1.5 3.1 2.6 7 2.6s7-1.1 7-2.6V5M5 12.2v3.2c0 1.5 3.1 2.6 7 2.6s7-1.1 7-2.6v-3.2"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"></path>
                                </svg>
                              </span>
                              <span class="insight-viz-ai__sig">
                                <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                                  <circle cx="6.5" cy="8" r="2.2" stroke="currentColor" stroke-width="1.75"></circle>
                                  <circle cx="17.5" cy="8" r="2.2" stroke="currentColor" stroke-width="1.75"></circle>
                                  <circle cx="12" cy="17" r="2.2" stroke="currentColor" stroke-width="1.75"></circle>
                                  <path
                                    d="M8.2 9.4 10.6 15M15.8 9.4 13.4 15"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"></path>
                                </svg>
                              </span>
                              <span class="insight-viz-ai__sig">
                                <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                                  <circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.75"></circle>
                                  <path
                                    d="M6.5 19.5v-.6c0-3.1 2.5-5.6 5.5-5.6s5.5 2.5 5.5 5.6v.6"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"></path>
                                </svg>
                              </span>
                              <span class="insight-viz-ai__sig">
                                <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                                  <path
                                    d="M12 3.5 19 7v6.5c0 4.2-2.8 8.1-7 11-4.2-2.9-7-6.8-7-11V7l7-3.5Z"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linejoin="round"></path>
                                  <path
                                    d="M9 12.2 11.2 14.5 15.8 9.5"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                </svg>
                              </span>
                              <span class="insight-viz-ai__sig">
                                <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                                  <path d="M12 3v4M12 17v4M4.6 12h4M15.4 12h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"
                                  ></path>
                                  <circle cx="12" cy="12" r="2.8" stroke="currentColor" stroke-width="1.75"></circle>
                                </svg>
                              </span>
                            </div>
                          </div>
                        </div>
                      )}
                    </div>
                    <div class="insight-card__main">
                      <p class="insight-card__tag">{p.tag}</p>
                      <h3 class="insight-card__title">{p.title}</h3>
                      <p class="insight-card__teaser" data-insight-teaser>{p.teaser}</p>
                    </div>
                  </div>
                  <span class="sr-only">Kontext zur Karte ein- oder ausblenden</span>
                  <span class="insight-card__summary-chev" aria-hidden="true">
                    <svg
                      class="insight-card__chev"
                      width="12"
                      height="12"
                      viewBox="0 0 14 14"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M3.5 5.5 7 9l3.5-3.5"></path>
                    </svg>
                  </span>
                </summary>
                <div class="insight-card__panel">
                  <div class="insight-card__panel-inner">
                    <ul class="insight-card__bullets" role="list">
                      {p.bullets.map((line) => (
                        <li>{line}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </details>
            </li>
          ))}
        </ul>

      </div>
    </section>
