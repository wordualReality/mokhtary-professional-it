---
export const prerender = true;
/**
 * @file src/pages/en/privacy.astro
 * @summary Privacy policy in Professional IT English context.
 */
import ProfilLaunchLayout from '../../layouts/ProfilLaunchLayout.astro';
import LegalDatenschutzArticle from '../../components/legal/LegalDatenschutzArticle.astro';
import { professionalLegalPathsEn } from '../../config/professional-navigation';

const title = 'Privacy Policy · Aydin Mokhtary · Professional IT';
const description =
  'Privacy policy under GDPR for mokhtary.de. No cookies, no tracking, no external fonts or CDNs. Controller: Aydin Mokhtary, Wedel.';
---

<ProfilLaunchLayout locale="en" title={title} description={description}>
  <main id="main-content" class="bg-white">
    <section class="relative border-b border-[var(--color-border-soft)]">
      <div class="mx-auto max-w-3xl px-6 py-20 lg:px-8 lg:py-24">
        <header class="mb-10" data-reveal>
          <p class="mb-3 text-sm font-medium uppercase tracking-[0.18em] text-[var(--color-primary)]">
            Legal
          </p>
          <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-base-dark)] md:text-5xl">
            Privacy Policy
          </h1>
          <p class="mt-4 text-base leading-7 text-[var(--color-text-secondary)]">
            Transparent and concise. This site uses no cookies, no tracking
            and no external services that transfer personal data to third parties.
            The only active data processing arises from hosting operations
            and emails you send to me.
          </p>
        </header>

        <LegalDatenschutzArticle privacyHref={professionalLegalPathsEn.privacy} />
      </div>
    </section>
  </main>
</ProfilLaunchLayout>
